#!/usr/bin/env sh

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
. "$SCRIPT_DIR/release.common.sh"

BIN_NAME="${BIN_NAME:-roff}"
init_common

parse_args() {
    if [ $# -eq 0 ]; then
        build_native
        return
    fi

    while [ $# -gt 0 ]; do
        case "$1" in
            all)
                build_all_targets
                ;;
            native)
                build_native
                ;;
            release)
                build_all_targets
                package_all_targets
                ;;
            verify)
                if [ -n "$2" ] && [ "${2#-}" = "$2" ]; then
                    verify_reproducibility "$2"
                    shift
                else
                    verify_reproducibility
                fi
                ;;
            -h|--help)
                show_usage
                exit 0
                ;;
            *)
                echo "Unknown option: $1"
                show_usage
                exit 1
                ;;
        esac
        shift
    done
}

parse_args "$@"
